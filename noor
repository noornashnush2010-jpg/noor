<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Link Checker</title>
  <style>
    body {
      font-family: Arial;
      background: #0f172a;
      color: white;
      text-align: center;
      padding: 50px;
    }

    input {
      width: 70%;
      padding: 12px;
      border-radius: 8px;
      border: none;
      margin-top: 20px;
    }

    button {
      padding: 12px 20px;
      margin-top: 10px;
      border: none;
      border-radius: 8px;
      background: #22c55e;
      color: white;
      cursor: pointer;
    }

    .result {
      margin-top: 20px;
      font-size: 20px;
    }
  </style>
</head>

<body>

  <h1>🔐 Link Safety Checker</h1>
  <p>ضع الرابط وتأكد هل هو آمن</p>

  <input id="url" placeholder="https://example.com">
  <br>
  <button onclick="checkLink()">فحص الرابط</button>

  <div class="result" id="result"></div>

  <script>
    function checkLink() {
      let url = document.getElementById("url").value;
      let result = document.getElementById("result");

      if (!url.startsWith("http")) {
        result.innerHTML = "❌ رابط غير صالح";
        return;
      }

      // فحص بسيط مبدئي
      if (url.includes("login") || url.includes("verify")) {
        result.innerHTML = "⚠️ رابط مشكوك فيه";
      } else {
        result.innerHTML = "✅ الرابط يبدو آمن";
      }
    }
  </script>

</body>
</html>
